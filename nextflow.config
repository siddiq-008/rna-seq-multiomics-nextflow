params {
    // SRA accession ID
    srr = 'SRR4101836'

    // Reference and input files
    gtf     = 'reference/annotation.gtf'
    index   = 'reference/hisat2_index/genome'
    protein = 'reference/protein.faa'
    counts  = 'data/important_genes.csv'

    // External database paths. Update this path on your system.
    eggnog_db = '/path/to/eggnog_db'

    // Optional metabolic model CSV. Keep empty if not used.
    metabolic_model = ''

    // Locus-tag prefix used while mapping metabolic model genes.
    locus_prefix = 'DJ41_'

    // Output directory
    outdir = 'results'
}

process {
    cpus   = 2
    memory = '4 GB'

    withName: DOWNLOAD_FASTQ {
        cpus = 4
        memory = '4 GB'
    }

    withName: FASTP {
        cpus = 4
        memory = '4 GB'
    }

    withName: HISAT2_ALIGN {
        cpus = 4
        memory = '8 GB'
    }

    withName: FEATURECOUNTS {
        cpus = 4
        memory = '6 GB'
    }

    withName: EGGNOG {
        cpus   = 12
        memory = '7 GB'
    }

    withName: INTEGRATION {
        cpus = 1
        memory = '4 GB'
    }
}
